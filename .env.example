# 디시인사이드 갤러리 설정
# GALLERY_TYPE: "board" = 일반갤러리, "mgallery" = 미니갤러리
GALLERY_TYPE=board
GALLERY_ID=roadcycle
# 갤러리 내 탭(말머리) 필터. 없으면 비워두기.
GALLERY_SUBJECT=탓워

# Google Sheets 설정
SPREADSHEET_ID=1cfKsH8EtWv3fDka4lfdF5t9WHlZvS7oY19ZdYcifYDY
WORKSHEET_NAME=시트1
SERVICE_ACCOUNT_FILE=service_account.json

# 요청 간 딜레이 (초)
MIN_DELAY=2
MAX_DELAY=5

# 한 사이클 내 최대 수집 페이지 수
MAX_PAGES=10

# 전체 갤러리 재스캔 주기 (초, 기본 10분)
POLL_INTERVAL=600
